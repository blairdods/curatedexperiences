# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Resend
RESEND_API_KEY=

# Google reCAPTCHA Essentials checkbox (contact page)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_PROJECT_ID=
RECAPTCHA_API_KEY=

# Google Analytics 4 (client-side tracking)
NEXT_PUBLIC_GA4_ID=

# Google Analytics Data API (server-side reporting — for analytics agent)
# 1. Enable the Analytics Data API in Google Cloud Console
# 2. Create a service account, download JSON key
# 3. Add service account email as Viewer in GA4 Property Access Management
GA4_PROPERTY_ID=
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY=

# Google Search Console API (server-side — for analytics agent)
# 1. Enable the Google Search Console API in Google Cloud Console
# 2. Use the same service account / key as GA4 above
# 3. Add service account email as an owner in Search Console property settings
GSC_SITE_URL=sc-domain:curatedexperiences.com
GSC_CLIENT_EMAIL=
GSC_PRIVATE_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=

# Cron job authentication
CRON_SECRET=

# Google Ads (managed separately)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
