# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Resend
RESEND_API_KEY=

# Google reCAPTCHA Essentials checkbox (contact page)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_PROJECT_ID=
RECAPTCHA_API_KEY=

# Google Analytics 4 (client-side tracking)
NEXT_PUBLIC_GA4_ID=

# Google Analytics Data API (server-side reporting — for analytics agent)
# 1. Enable the Analytics Data API in Google Cloud Console
# 2. Create a service account, download JSON key
# 3. Add service account email as Viewer in GA4 Property Access Management
GA4_PROPERTY_ID=
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY=

# Google Search Console API (server-side — for analytics agent)
# 1. Enable the Google Search Console API in Google Cloud Console
# 2. Use the same service account / key as GA4 above
# 3. Add service account email as an owner in Search Console property settings
GSC_SITE_URL=sc-domain:curatedexperiences.com
GSC_CLIENT_EMAIL=
GSC_PRIVATE_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=

# Cron job authentication
CRON_SECRET=

# Google Ads API (server-side reporting; service account is preferred)
# Add GOOGLE_ADS_SERVICE_ACCOUNT_EMAIL as a read-only user in Google Ads.
# GA4_CLIENT_EMAIL / GA4_PRIVATE_KEY are used as a fallback when a dedicated
# Ads service account is not supplied.
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_SERVICE_ACCOUNT_EMAIL=
GOOGLE_ADS_PRIVATE_KEY=

# Public Google tag and conversion labels (safe to expose in browser markup)
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-18032876556
NEXT_PUBLIC_GOOGLE_ADS_LEAD_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_EMAIL_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_CONCIERGE_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_HIGH_INTENT_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_BRIEF_LABEL=

# Enable only after accepting Google's customer-data terms in Google Ads.
NEXT_PUBLIC_GOOGLE_ADS_ENHANCED_CONVERSIONS=false
